# ==========================================
# CONFIGURACIÓN DEL SERVIDOR
# ==========================================
PORT=3000
NODE_ENV=development

# ==========================================
# SEGURIDAD Y CORS
# ==========================================
# MUY IMPORTANTE: En producción, cambia esto por el dominio real de Pueba_CATH
FRONTEND_URL=http://localhost:5173

# ==========================================
# BASE DE DATOS
# ==========================================
# URL de conexión directa para Prisma (si ejecutas npm run dev sin Docker)
DATABASE_URL=postgresql://postgres:securepassword123@localhost:5432/puebacath_db?schema=public

# Credenciales inyectadas al contenedor de PostgreSQL por docker-compose
POSTGRES_USER=postgres
POSTGRES_PASSWORD=securepassword123
POSTGRES_DB=puebacath_db

# ==========================================
# AUTENTICACIÓN
# ==========================================
# Cambiar por una cadena aleatoria y larga en el VPS
JWT_SECRET=super_secret_key_change_me_in_production
JWT_EXPIRES_IN=24h

# ==========================================
# SERVICIOS EXTERNOS (Fase Posterior)
# ==========================================
# RESEND_API_KEY=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
